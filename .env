# Обязательно
TELEGRAM_TOKEN=your_telegram_bot_token_here

# HH.ru OAuth (обязательно для реальных вакансий)
# https://dev.hh.ru/admin
HH_CLIENT_ID=your_hh_client_id
HH_CLIENT_SECRET=your_hh_client_secret
HH_USER_AGENT=JobSearchBot/1.0 (your_real_email@example.com)

# SuperJob (опционально)
# https://api.superjob.ru
SUPERJOB_KEY=your_superjob_secret_key

# DeepSeek (опционально)
# https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# Для webhook на Render (опционально)
RENDER_EXTERNAL_URL=https://your-service.onrender.com
